[Unit]
Description=Ghostwriter NFC API (uvicorn)
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/ghostwriter
ExecStart=/home/pi/ghostwriter/.venv/bin/uvicorn api_server:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target